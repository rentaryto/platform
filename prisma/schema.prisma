generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  apartments Apartment[]
}

model Apartment {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  name               String
  address            String
  cadastralReference String?
  rentAmount         Decimal
  status             String   @default("occupied")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  currentTenant   Tenant?  @relation("CurrentTenant", fields: [currentTenantId], references: [id])
  currentTenantId String?  @unique

  tenantHistory      Tenant[]           @relation("TenantHistory")
  recurringExpenses  RecurringExpense[]
  unexpectedExpenses UnexpectedExpense[]
  documents          Document[]
  reminders          Reminder[]
}

model Tenant {
  id             String    @id @default(uuid())
  name           String
  email          String
  phone          String?
  leaseStartDate DateTime
  leaseEndDate   DateTime?
  createdAt      DateTime  @default(now())

  currentApartment Apartment? @relation("CurrentTenant")

  apartmentId      String?
  apartmentHistory Apartment? @relation("TenantHistory", fields: [apartmentId], references: [id])
}

model RecurringExpense {
  id          String    @id @default(uuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  name        String
  amount      Decimal
  frequency   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UnexpectedExpense {
  id          String    @id @default(uuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  description String
  amount      Decimal
  date        DateTime
  createdAt   DateTime  @default(now())
}

model Document {
  id          String    @id @default(uuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  type        String
  subtype     String?
  fileName    String
  fileUrl     String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  sendStatus  String    @default("not_applicable")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Reminder {
  id          String    @id @default(uuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  title       String
  description String?
  dueDate     DateTime
  type        String    @default("custom")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
}
